{
  "name": "squadron",
  "private": true,
  "version": "0.1.3",
  "type": "module",
  "description": "A local cockpit for commanding Claude agents across your fleet of GitHub repos.",
  "author": "RaihanStark <dev@byraihan.com>",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "node --watch server/index.js",
    "dev:web": "npm --prefix web run dev",
    "setup": "npm install && npm --prefix web install",
    "build:web": "npm --prefix web run build",
    "electron": "electron .",
    "test": "node --test",
    "dist": "npm run build:web && electron-builder --linux rpm"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.195",
    "express": "^4.21.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.byraihan.squadron",
    "productName": "Squadron",
    "asar": false,
    "files": [
      "**/*",
      "!web/node_modules",
      "!web/src",
      "!web/public",
      "!web/index.html",
      "!web/vite.config.js",
      "!web/package*.json",
      "!docs",
      "!.github",
      "!**/*.md",
      "!scratchpad"
    ],
    "directories": {
      "output": "dist-electron"
    },
    "linux": {
      "target": [
        "rpm"
      ],
      "category": "Development",
      "icon": "build/icon.png",
      "maintainer": "RaihanStark <dev@byraihan.com>",
      "synopsis": "Command Claude agents across your GitHub repos"
    }
  }
}
